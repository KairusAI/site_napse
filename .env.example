# Copie para `.env` e ajuste. Número WhatsApp: somente dígitos (DDD + número, com DDI 55 se for Brasil).
# VITE_WHATSAPP_PHONE=5511999999999

# Mensagem inicial ao abrir o WhatsApp (pode trocar pelo tom da marca).
# VITE_WHATSAPP_DEFAULT_MESSAGE=Olá! Gostaria de falar com um especialista da NAPSE.

# Atendimento (exibido no contato; texto livre).
# VITE_BUSINESS_HOURS=Segunda a sexta, 8h às 18h (horário de Brasília).

# Redes sociais (URL completa; deixe vazio para ocultar o ícone no rodapé).
# VITE_INSTAGRAM_URL=https://www.instagram.com/seu_perfil
# VITE_LINKEDIN_URL=https://www.linkedin.com/company/sua-empresa
# VITE_YOUTUBE_URL=https://www.youtube.com/@seu_canal
